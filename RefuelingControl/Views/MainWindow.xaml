<Window x:Class="RefuelingControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RefuelingControl" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BARRA SUPERIOR -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título con icono -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="25,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⛽" FontSize="26" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="RefuelingControl" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menú Hamburguesa -->
                <Button Grid.Column="1"
                        x:Name="MenuButton"
                        Content="☰"
                        FontSize="24"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="60"
                        Height="60"
                        Margin="0,0,20,0"
                        Cursor="Hand"
                        Click="MenuButton_Click"/>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========================================== -->
            <!-- SELECTOR DE VEHÍCULO Y ACCIONES DE REPOSTAJE -->
            <!-- (siempre visible, encima de la lista/formulario) -->
            <!-- ========================================== -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Effect="{StaticResource CardShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="VEHÍCULO" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbVehicleSelector"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  SelectionChanged="VehicleSelector_SelectionChanged"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="txtSelectedVehicleInfo"
                                   Grid.Column="0"
                                   Text="Selecciona un vehículo para gestionar sus repostajes"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnNewRefuel"
                                    Content="⛽ Nuevo repostaje"
                                    Width="150" Height="38"
                                    FontSize="13"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,10,0"
                                    IsEnabled="False"
                                    Click="NewRefuel_Click"/>

                            <Button x:Name="btnListRefuels"
                                    Content="📋 Listar repostajes"
                                    Width="160" Height="38"
                                    FontSize="13"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    IsEnabled="False"
                                    Click="ListRefuels_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!-- VISTA DE LISTA DE VEHÍCULOS (por defecto) -->
            <!-- ========================================== -->
            <Grid x:Name="ListViewContainer" Grid.Row="1" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Effect="{StaticResource CardShadowEffect}"/>

                <Border Grid.Row="0" Padding="18,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="LISTA DE VEHÍCULOS" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <ListView x:Name="VehiclesListView"
                          Grid.Row="1"
                          Background="Transparent"
                          FontSize="14"
                          BorderThickness="0"
                          Margin="4,0,4,4"
                          ItemContainerStyle="{StaticResource ModernListViewItemStyle}">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource ModernGridHeaderStyle}">
                            <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Header="Tipo" Width="120" DisplayMemberBinding="{Binding VehicleType}"/>
                            <GridViewColumn Header="Nombre" Width="140" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Matrícula" Width="130" DisplayMemberBinding="{Binding LicensePlate}"/>
                            <GridViewColumn Header="Marca" Width="120" DisplayMemberBinding="{Binding Brand}"/>
                            <GridViewColumn Header="Modelo" Width="120" DisplayMemberBinding="{Binding Model}"/>
                            <GridViewColumn Header="Año" Width="70" DisplayMemberBinding="{Binding Year}"/>
                            <GridViewColumn Header="Combustible" Width="130" DisplayMemberBinding="{Binding FuelType}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <!-- ========================================== -->
            <!-- FORMULARIO DE CREAR VEHÍCULO               -->
            <!-- ========================================== -->
            <Grid x:Name="CreateFormContainer" Grid.Row="1" Visibility="Collapsed">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="30"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Effect="{StaticResource CardShadowEffect}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Título del formulario -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="🚗" FontSize="24" Margin="0,0,10,0"/>
                            <TextBlock Text="Nuevo Vehículo" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" * Campos obligatorios" FontSize="13" Foreground="{StaticResource DangerBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Grid de 2 columnas para el formulario -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- COLUMNA IZQUIERDA -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,15,10">
                                <TextBlock Text="Nombre del Vehículo *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtVehicleName" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="15,0,0,10">
                                <TextBlock Text="Matrícula *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtLicensePlate" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,15,10">
                                <TextBlock Text="Marca *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtBrand" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="15,0,0,10">
                                <TextBlock Text="Modelo *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtModel" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <!-- Tipo de Vehículo -->
                            <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,15,10">
                                <TextBlock Text="Tipo de Vehículo *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbVehicleType" Style="{StaticResource ModernComboBoxStyle}">
                                    <ComboBoxItem Content="Seleccionar..." IsSelected="True"/>
                                    <ComboBoxItem Content="🚗 Coche"/>
                                    <ComboBoxItem Content="🏍️ Motocicleta"/>
                                    <ComboBoxItem Content="🛺 Quad"/>
                                    <ComboBoxItem Content="🚐 Furgoneta"/>
                                    <ComboBoxItem Content="🚛 Camión"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="2" Margin="15,0,0,10">
                                <TextBlock Text="Año *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtYear" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,15,10">
                                <TextBlock Text="Tipo de Combustible *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbFuelType" Style="{StaticResource ModernComboBoxStyle}">
                                    <ComboBoxItem Content="Seleccionar..." IsSelected="True"/>
                                    <ComboBoxItem Content="Diesel"/>
                                    <ComboBoxItem Content="Gasolina"/>
                                    <ComboBoxItem Content="Etanol"/>
                                    <ComboBoxItem Content="GLP (Gas Licuado)"/>
                                    <ComboBoxItem Content="GNC (Gas Natural)"/>
                                    <ComboBoxItem Content="Eléctrico"/>
                                    <ComboBoxItem Content="Flex"/>
                                    <ComboBoxItem Content="GNL (Gas Natural Licuado)"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Descripción (ocupa toda la fila) -->
                            <StackPanel Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Descripción" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtDescription" Height="80" Style="{StaticResource ModernTextBoxStyle}" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Botones de acción -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="btnCancelCreate"
                                    Content="Cancelar"
                                    Width="120" Height="40"
                                    FontSize="14"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,0"
                                    Click="CancelCreate_Click"/>

                            <Button x:Name="btnSaveVehicle"
                                    Content="💾 Guardar Vehículo"
                                    Width="160" Height="40"
                                    FontSize="14"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveVehicle_Click"/>
                        </StackPanel>

                        <!-- Mensaje de error/éxito -->
                        <TextBlock x:Name="txtFormMessage"
                                   Grid.Row="3"
                                   FontSize="14"
                                   Foreground="{StaticResource DangerBrush}"
                                   Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- MENÚ DESPLEGABLE (POPUP) -->
        <Popup x:Name="MenuPopup"
               PlacementTarget="{Binding ElementName=MenuButton}"
               Placement="Bottom"
               StaysOpen="False"
               Width="250"
               AllowsTransparency="True"
               PopupAnimation="Slide">

            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12"
                    Padding="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource DropShadowEffect}">

                <StackPanel>
                    <Button Content="➕ Crear nuevo vehículo"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="CreateVehicle_Click"
                            Height="45"
                            FontSize="15"
                            Margin="0,2"/>

                    <Button Content="🗑️ Borrar vehículo existente"
                            Style="{StaticResource MenuButtonStyle}"
                            Foreground="{StaticResource DangerBrush}"
                            Click="DeleteVehicle_Click"
                            Height="45"
                            FontSize="15"
                            Margin="0,2"/>

                    <Button Content="🔄 Actualizar lista"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="ViewAllVehicles_Click"
                            Height="45"
                            FontSize="15"
                            Margin="0,2"/>

                    <Button Content="🚪 Salir"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Exit_Click"
                            Height="45"
                            FontSize="15"
                            Margin="0,2"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
